{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "src/shared/**/*.ts", "src/daemon/**/*.ts", "src/agent/**/*.ts"],
  "exclude": ["node_modules", "dist", "release", "tests", "src/renderer"]
}
