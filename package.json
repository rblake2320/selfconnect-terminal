{
  "name": "selfconnect-terminal",
  "version": "2.0.0",
  "description": "SelfConnect Terminal — a governed agent execution surface with a real PTY terminal, live widgets, daemon-owned model routing, cost kernel, approval gates, secret redaction, a hash-chained audit ledger, session persistence, slash commands, an MCP client/server, a headless CLI + typed SDK, a governed tool layer, and live A2A (BPC/TSK) transport.",
  "author": "SelfConnect",
  "license": "MIT",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "bin": {
    "selfconnect": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./contracts": {
      "types": "./dist/shared/contracts.d.ts",
      "default": "./dist/shared/contracts.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build": "npm run build:renderer && npm run build:electron && npm run build:cli",
    "build:preview": "SELFCONNECT_PREVIEW=1 vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.cli.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "electron-rebuild -f -w node-pty",
    "dist": "npm run build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-pty": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
