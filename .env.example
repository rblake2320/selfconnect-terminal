# SelfConnect Terminal — daemon configuration.
# Provider keys live ONLY here, in the daemon process. The renderer never sees them.
# Copy to .env and fill in. Local-only mode is ON by default (cloud hard-blocked).

SELFCONNECT_LOCAL_ONLY=true
SELFCONNECT_LEDGER_PATH=./data/selfconnect-ledger.jsonl
SELFCONNECT_MAX_SPEND_PER_CALL=0.25
SELFCONNECT_APPROVAL_TIMEOUT_MS=120000

# Local provider (Ollama) — free, always allowed.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# OpenAI-compatible cloud provider (optional).
OPENAI_COMPAT_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# Anthropic cloud provider (optional).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_INPUT_PRICE=0
ANTHROPIC_OUTPUT_PRICE=0

# Baseline cloud pricing (USD per 1M tokens) used to compute "avoided" spend on local calls.
COST_BASELINE_INPUT_PRICE=3
COST_BASELINE_OUTPUT_PRICE=15

# --- v2 ---------------------------------------------------------------------

# Session persistence: snapshots are written here so sessions can be resumed.
SELFCONNECT_SESSIONS_DIR=./data/sessions

# Agent-to-agent (A2A) transport over hash-chained BPC envelopes (TSK).
#   file = file-mailbox backend (default), ws = WebSocket backend, off = disabled
SELFCONNECT_A2A_MODE=file
SELFCONNECT_A2A_DIR=./data/a2a
SELFCONNECT_A2A_WS_PORT=8787
# Comma-separated peer names allowed WITHOUT per-message approval. Sending to a
# non-allowlisted peer (or ANY 'handoff' kind) always requires an approval.
SELFCONNECT_A2A_ALLOWLIST=

# MCP client: path to the server registry (see mcp-servers.json.example).
SELFCONNECT_MCP_CONFIG=./mcp-servers.json

# Governed tool layer: per-write checkpoints (for /rewind) + lifecycle hooks.
SELFCONNECT_CHECKPOINTS_DIR=./data/checkpoints
SELFCONNECT_HOOKS_CONFIG=./hooks.json

# Optional web_search backend for the governed web_search tool (cloud; blocked
# under LOCAL_ONLY). Leave blank to disable.
SEARCH_API_URL=
SEARCH_API_KEY=

# --- v3c: Proof layer -------------------------------------------------------

# Confidence routing: when a tool reports a confidence below this threshold AND
# the action is high-blast-radius (mutating or risk>=high), it is escalated to a
# human approval instead of running. Range 0..1 (clamped). Default 0.5.
SELFCONNECT_CONFIDENCE_THRESHOLD=0.5
